{
  "version": 2,
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/chat/completions", "dest": "/api/chat/completions.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
